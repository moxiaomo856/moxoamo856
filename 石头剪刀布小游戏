<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MOMO币石头剪刀布 - PAXI游戏</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Arial', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
            color: white;
        }
        
        .container {
            max-width: 500px;
            margin: 0 auto;
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 30px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }
        
        .header {
            text-align: center;
            margin-bottom: 30px;
        }
        
        .header h1 {
            font-size: 28px;
            margin-bottom: 10px;
            background: linear-gradient(45deg, #ff6b6b, #feca57);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .wallet-section {
            background: rgba(255, 255, 255, 0.15);
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 30px;
        }
        
        .wallet-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }
        
        .connect-btn {
            background: linear-gradient(45deg, #4facfe, #00f2fe);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: 50px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.3s;
        }
        
        .connect-btn:hover {
            transform: translateY(-2px);
        }
        
        .balance {
            font-size: 14px;
            opacity: 0.9;
        }
        
        .game-section {
            background: rgba(255, 255, 255, 0.15);
            padding: 25px;
            border-radius: 15px;
            margin-bottom: 30px;
        }
        
        .section-title {
            font-size: 20px;
            margin-bottom: 20px;
            text-align: center;
            color: #feca57;
        }
        
        .bet-input {
            display: flex;
            gap: 15px;
            margin-bottom: 20px;
        }
        
        .input-group {
            flex: 1;
        }
        
        .input-group label {
            display: block;
            margin-bottom: 8px;
            font-size: 14px;
            opacity: 0.9;
        }
        
        .input-group input {
            width: 100%;
            padding: 12px;
            border-radius: 10px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            background: rgba(255, 255, 255, 0.1);
            color: white;
            font-size: 16px;
        }
        
        .move-selection {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            margin-bottom: 25px;
        }
        
        .move-btn {
            flex: 1;
            padding: 15px;
            border: none;
            border-radius: 10px;
            background: rgba(255, 255, 255, 0.2);
            color: white;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .move-btn:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: scale(1.05);
        }
        
        .move-btn.selected {
            background: linear-gradient(45deg, #ff6b6b, #ee5a52);
            box-shadow: 0 5px 15px rgba(255, 107, 107, 0.4);
        }
        
        .action-btn {
            width: 100%;
            padding: 16px;
            border: none;
            border-radius: 50px;
            background: linear-gradient(45deg, #ff9a9e, #fad0c4);
            color: #333;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            transition: transform 0.3s;
            margin-bottom: 15px;
        }
        
        .action-btn:hover {
            transform: translateY(-2px);
        }
        
        .action-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }
        
        .game-status {
            text-align: center;
            padding: 15px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
            margin-top: 20px;
            min-height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .status-text {
            font-size: 16px;
        }
        
        .game-history {
            background: rgba(255, 255, 255, 0.1);
            padding: 20px;
            border-radius: 15px;
        }
        
        .history-title {
            font-size: 18px;
            margin-bottom: 15px;
            color: #4facfe;
        }
        
        .history-list {
            max-height: 200px;
            overflow-y: auto;
        }
        
        .history-item {
            padding: 10px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            font-size: 14px;
        }
        
        .history-item:last-child {
            border-bottom: none;
        }
        
        .win {
            color: #4cd964;
        }
        
        .lose {
            color: #ff3b30;
        }
        
        .draw {
            color: #ffcc00;
        }
        
        .loading {
            display: none;
            text-align: center;
            padding: 20px;
        }
        
        .spinner {
            border: 4px solid rgba(255, 255, 255, 0.3);
            border-top: 4px solid #4facfe;
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto 15px;
        }
        
        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
        
        @media (max-width: 480px) {
            .container {
                padding: 20px;
            }
            
            .move-selection {
                flex-direction: column;
            }
            
            .bet-input {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🎮 MOMO币石头剪刀布</h1>
            <p>双代币消耗游戏 · 赢取PAXI和MOMO币</p>
        </div>
        
        <div class="wallet-section">
            <div class="wallet-info">
                <div>
                    <div>钱包状态: <span id="wallet-status">未连接</span></div>
                    <div class="balance">PAXI余额: <span id="paxi-balance">0</span></div>
                    <div class="balance">MOMO余额: <span id="momo-balance">0</span></div>
                </div>
                <button class="connect-btn" id="connect-btn">连接PaxiHub钱包</button>
            </div>
            <div id="wallet-address" style="font-size: 12px; word-break: break-all; margin-top: 10px;"></div>
        </div>
        
        <div class="game-section">
            <h2 class="section-title">🎯 创建新游戏</h2>
            
            <div class="bet-input">
                <div class="input-group">
                    <label>PAXI赌注 (最小: 0.1 PAXI)</label>
                    <input type="number" id="paxi-bet" placeholder="0.1" step="0.1" min="0.1">
                </div>
                <div class="input-group">
                    <label>MOMO赌注 (最小: 100 MOMO)</label>
                    <input type="number" id="momo-bet" placeholder="100" step="10" min="100">
                </div>
            </div>
            
            <button class="action-btn" id="create-game-btn">创建游戏房间</button>
            
            <div class="game-status">
                <div id="game-status-text">等待创建或加入游戏...</div>
            </div>
        </div>
        
        <div class="game-section">
            <h2 class="section-title">✊ 出招选择</h2>
            
            <div class="move-selection">
                <button class="move-btn" data-move="rock">✊ 石头</button>
                <button class="move-btn" data-move="paper">✋ 布</button>
                <button class="move-btn" data-move="scissors">✌️ 剪刀</button>
            </div>
            
            <button class="action-btn" id="submit-move-btn" disabled>确认出招</button>
            <button class="action-btn" id="join-game-btn" disabled>加入游戏</button>
            <button class="action-btn" id="claim-prize-btn" disabled>领取奖励</button>
        </div>
        
        <div class="game-history">
            <h3 class="history-title">📊 游戏记录</h3>
            <div class="history-list" id="history-list">
                <!-- 游戏记录会动态添加到这里 -->
            </div>
        </div>
        
        <div class="loading" id="loading">
            <div class="spinner"></div>
            <div>处理中，请稍候...</div>
        </div>
    </div>

    <!-- 引入PAXI SDK -->
    <script src="https://mainnet-api.paxinet.io/resources/js/paxi-cosmjs.umd.js"></script>
    
    <script>
        // 游戏配置
        const CONFIG = {
            rpc: 'https://mainnet-rpc.paxinet.io',
            lcd: 'https://mainnet-lcd.paxinet.io',
            gameContract: '', // 游戏合约地址（部署后填写）
            momoToken: '',    // MOMO币合约地址（创建后填写）
            denom: 'upaxi'
        };

        // 游戏状态
        let gameState = {
            walletConnected: false,
            currentGameId: null,
            selectedMove: null,
            playerAddress: null,
            gameList: []
        };

        // DOM元素
        const connectBtn = document.getElementById('connect-btn');
        const createGameBtn = document.getElementById('create-game-btn');
        const submitMoveBtn = document.getElementById('submit-move-btn');
        const joinGameBtn = document.getElementById('join-game-btn');
        const claimPrizeBtn = document.getElementById('claim-prize-btn');
        const moveButtons = document.querySelectorAll('.move-btn');
        const loadingElement = document.getElementById('loading');

        // 连接钱包
        connectBtn.addEventListener('click', async () => {
            try {
                showLoading();
                
                // 检查PaxiHub是否注入
                if (typeof window.paxihub !== 'undefined') {
                    const hub = window.paxihub;
                    const addressInfo = await hub.paxi.getAddress();
                    
                    gameState.walletConnected = true;
                    gameState.playerAddress = addressInfo.address;
                    
                    document.getElementById('wallet-status').textContent = '已连接';
                    document.getElementById('wallet-address').textContent = `地址: ${addressInfo.address}`;
                    connectBtn.textContent = '已连接';
                    connectBtn.disabled = true;
                    
                    // 更新余额
                    await updateBalances();
                    
                    hideLoading();
                    alert('钱包连接成功！');
                } else if (/Mobi/.test(navigator.userAgent)) {
                    // 手机端深度链接
                    window.location.href = `paxi://hub/explorer?url=${encodeURIComponent(window.location.href)}`;
                    
                    setTimeout(() => {
                        window.location.href = 'https://paxinet.io/paxi_docs/paxihub#paxihub-application';
                    }, 1000);
                } else {
                    alert('请在手机PaxiHub应用中打开此页面');
                }
            } catch (error) {
                hideLoading();
                alert('连接失败: ' + error.message);
            }
        });

        // 更新余额
        async function updateBalances() {
            if (!gameState.walletConnected) return;
            
            try {
                // 获取PAXI余额
                const paxiBalance = await fetch(`${CONFIG.lcd}/cosmos/bank/v1beta1/balances/${gameState.playerAddress}`)
                    .then(r => r.json())
                    .then(data => {
                        const paxiCoin = data.balances.find(b => b.denom === CONFIG.denom);
                        return paxiCoin ? (parseInt(paxiCoin.amount) / 1000000).toFixed(6) : '0';
                    });
                
                document.getElementById('paxi-balance').textContent = paxiBalance;
                
                // 获取MOMO币余额（需要MOMO币合约地址）
                if (CONFIG.momoToken) {
                    // 这里需要调用MOMO币合约的balanceOf查询
                    // 暂时用模拟数据
                    document.getElementById('momo-balance').textContent = '1000';
                }
            } catch (error) {
                console.error('更新余额失败:', error);
            }
        }

        // 创建游戏
        createGameBtn.addEventListener('click', async () => {
            if (!gameState.walletConnected) {
                alert('请先连接钱包');
                return;
            }
            
            const paxiBet = document.getElementById('paxi-bet').value;
            const momoBet = document.getElementById('momo-bet').value;
            
            if (!paxiBet || !momoBet) {
                alert('请输入赌注金额');
                return;
            }
            
            try {
                showLoading();
                
                // 这里需要调用游戏合约的createGame函数
                // 需要先授权MOMO币给游戏合约
                
                // 1. 授权MOMO币
                const approveMsg = {
                    increase_allowance: {
                        spender: CONFIG.gameContract,
                        amount: (parseFloat(momoBet) * 1000000).toString() // 考虑小数位
                    }
                };
                
                // 2. 创建游戏交易
                const createGameMsg = {
                    create_game: {
                        bet_paxi: (parseFloat(paxiBet) * 1000000).toString(), // upaxi单位
                        bet_momo: (parseFloat(momoBet) * 1000000).toString()  // umomo单位
                    }
                };
                
                // 构建并发送交易
                await buildAndSendTx([approveMsg, createGameMsg], "创建石头剪刀布游戏");
                
                hideLoading();
                alert('游戏创建成功！等待对手加入...');
                
                // 更新游戏状态
                document.getElementById('game-status-text').textContent = '游戏已创建，等待对手加入...';
                joinGameBtn.disabled = false;
                
            } catch (error) {
                hideLoading();
                alert('创建游戏失败: ' + error.message);
            }
        });

        // 选择出招
        moveButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                moveButtons.forEach(b => b.classList.remove('selected'));
                btn.classList.add('selected');
                gameState.selectedMove = btn.dataset.move;
                submitMoveBtn.disabled = false;
            });
        });

        // 提交出招
        submitMoveBtn.addEventListener('click', async () => {
            if (!gameState.selectedMove) {
                alert('请选择出招');
                return;
            }
            
            try {
                showLoading();
                
                // 转换出招为合约格式
                let moveValue;
                switch(gameState.selectedMove) {
                    case 'rock': moveValue = 0; break;
                    case 'paper': moveValue = 1; break;
                    case 'scissors': moveValue = 2; break;
                }
                
                const makeMoveMsg = {
                    make_move: {
                        game_id: gameState.currentGameId,
                        player_move: moveValue
                    }
                };
                
                await buildAndSendTx([makeMoveMsg], "提交出招");
                
                hideLoading();
                alert('出招成功！等待对手出招...');
                
            } catch (error) {
                hideLoading();
                alert('出招失败: ' + error.message);
            }
        });

        // 加入游戏
        joinGameBtn.addEventListener('click', async () => {
            try {
                showLoading();
                
                // 这里需要先获取可加入的游戏列表
                // 然后让用户选择加入哪个游戏
                
                const joinGameMsg = {
                    join_game: {
                        game_id: gameState.currentGameId // 需要从列表中选择
                    }
                };
                
                await buildAndSendTx([joinGameMsg], "加入游戏");
                
                hideLoading();
                alert('成功加入游戏！请选择出招。');
                submitMoveBtn.disabled = false;
                
            } catch (error) {
                hideLoading();
                alert('加入游戏失败: ' + error.message);
            }
        });

        // 领取奖励
        claimPrizeBtn.addEventListener('click', async () => {
            try {
                showLoading();
                
                const claimMsg = {
                    claim_prize: {
                        game_id: gameState.currentGameId
                    }
                };
                
                await buildAndSendTx([claimMsg], "领取游戏奖励");
                
                hideLoading();
                alert('奖励领取成功！');
                
                // 更新余额
                await updateBalances();
                
            } catch (error) {
                hideLoading();
                alert('领取奖励失败: ' + error.message);
            }
        });

        // 构建和发送交易（基于您提供的文档代码）
        async function buildAndSendTx(messages, memo = "") {
            // 这里使用您提供的文档中的buildAndSendTx函数
            // 需要根据实际合约消息结构进行调整
            
            const chainId = await fetch(`${CONFIG.rpc}/status`)
                .then(r => r.json())
                .then(d => d.result.node_info.network);

            const sender = await window.paxihub.paxi.getAddress();
            
            // 构建交易...
            // 这里需要根据实际合约调整
            
            alert('交易构建完成，请在钱包中确认');
        }

        // 显示/隐藏加载动画
        function showLoading() {
            loadingElement.style.display = 'block';
        }

        function hideLoading() {
            loadingElement.style.display = 'none';
        }

        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            // 检查是否在PaxiHub中
            if (typeof window.paxihub !== 'undefined') {
                connectBtn.textContent = '点击连接钱包';
            }
            
            // 添加示例游戏记录
            const historyList = document.getElementById('history-list');
            const sampleHistory = [
                { result: 'win', opponent: '0x123...abc', amount: '10 PAXI + 1000 MOMO', time: '2分钟前' },
                { result: 'lose', opponent: '0x456...def', amount: '5 PAXI + 500 MOMO', time: '1小时前' },
                { result: 'draw', opponent: '0x789...ghi', amount: '3 PAXI + 300 MOMO', time: '3小时前' }
            ];
            
            sampleHistory.forEach(item => {
                const div = document.createElement('div');
                div.className = `history-item ${item.result}`;
                div.innerHTML = `
                    <div>${item.result === 'win' ? '🏆 胜利' : item.result === 'lose' ? '💔 失败' : '🤝 平局'}</div>
                    <div>对手: ${item.opponent}</div>
                    <div>金额: ${item.amount}</div>
                    <div>时间: ${item.time}</div>
                `;
                historyList.appendChild(div);
            });
        });
    </script>
</body>
</html>
